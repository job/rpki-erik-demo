#!/usr/bin/perl

use warnings;
use strict;

use Getopt::Long;

use APNIC::RPKI::Erik::Updater;

sub usage
{
    print <<EOF;
Usage:
$0 --cache-dir {cache-dir} --httpd-dir {httpd-dir}
   [--dir-count {dir-count} --char-count {char-count}]
   [--mft-per-partition {mft-per-partition}]
   [--total-partitions {total-partitions}]
   --write-snapshots

Writes Erik content to httpd-dir, based on the current state of
cache-dir.

The dir-count and char-count values are used to construct a directory
hierarchy for file storage.  Each file is stored has dir-count groups
of char-count characters removed from its front, with each group
forming another directory in the hierarchy.  By default, both values
are zero (i.e. all files are stored in a single directory).

The mft-per-partition value specifies the number of manifests that
will be stored in each partition (defaults to 1).  Alternatively, the
total number of partitions to be written may be specified instead.
EOF

    exit(10);
}

my %options;
GetOptions(\%options, 'cache-dir=s', 'httpd-dir=s',
                      'dir-count=i', 'char-count=i');
                      'mft-per-partition=i', 'total-partitions=i',
                      'write-snapshots');
if (not $options{'cache-dir'}) {
    print "Please provide a cache directory.\n";
    usage();
}
if (not $options{'httpd-dir'}) {
    print "Please provide a httpd directory.\n";
    usage();
}

my $cache_dir  = $options{'cache-dir'};
my $httpd_dir  = $options{'httpd-dir'};
my $dir_count  = $options{'dir-count'} || 0;
my $char_count = $options{'char-count'} || 0;
my $mft_per_partition = $options{'mft-per-partition'};
my $total_partitions  = $options{'total-partitions'};
my $write_snapshots   = exists $options{'write-snapshots'} ? 1 : 0;

my $updater =
    APNIC::RPKI::Erik::Updater->new(
        $cache_dir, $httpd_dir,
        dir_count  => $dir_count,
        char_count => $char_count,
        mft_per_partition => $mft_per_partition,
        total_partitions  => $total_partitions,
        write_snapshots   => $write_snapshots,
    );
$updater->synchronise();

1;
