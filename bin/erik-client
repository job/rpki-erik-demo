#!/usr/bin/perl

use warnings;
use strict;

use File::Slurp qw(read_file);
use Getopt::Long;

use APNIC::RPKI::Erik::Client;

sub usage
{
    print <<EOF;
Usage:
$0 --cache-dir {cache-dir} --server {host[:port]}
   [--fqdn {fqdn}] [--fqdn-path {fqdn-path}]
   [--use-snapshots] [--use-ttqs] [--out-dir {out-dir}] [--no-gc]
   [--procs {procs}] [--snapshot-procs {snapshot-procs}]
   [--adaptive] [--snapshots-only]
   [--partition-data-path {partition-data-path}]

Synchronises the local cache against the specified server for the
specified RPKI repository FQDN.

If --use-snapshots is set, then this will reinitialise the local state
based on the snapshot.

If --out-dir is set, then new files will be written to that directory,
instead of directly to the cache directory.

By default, files that are no longer available remotely will be
removed from the cache directory.  If --no-gc is set, then those files
will be left in place.  Specifying --out-dir enables --no-gc
implicitly.

{fqdn} is a literal FQDN, while {fqdn-path} is the path to a file
containing a list of FQDNs.  One or the other must be provided.

{procs} is the number of concurrent requests that can be on foot at
the same time.  {snapshot-procs} is the same, but limited to snapshot
fetches.  --adaptive reduces the number of concurrent requests that
are in play when a timeout error is received.

--snapshots-only skips tree synchronisation after loading from
snapshots.

{partition-data-path} is the output from calling erik-partitioner for
the FQDNs being synchronised here.  Providing that data will save
erik-client having to generate it.
EOF

    exit(10);
}

my %options;
GetOptions(\%options, 'cache-dir=s', 'server=s',
                      'fqdn=s', 'fqdn-path=s',
                      'use-snapshots', 'use-ttqs',
                      'out-dir=s', 'no-gc',
                      'procs=i', 'snapshot-procs=i',
                      'adaptive', 'snapshots-only',
                      'partition-data-path=s');
if (not $options{'cache-dir'}) {
    print "Please provide a cache directory.\n";
    usage();
}
if (not $options{'server'}) {
    print "Please provide a server.\n";
    usage();
}
if ((not $options{'fqdn'})
        and (not $options{'fqdn-path'})) {
    print "Please provide an FQDN or an FQDN file path.\n";
    usage();
}

my $cache_dir = $options{'cache-dir'};
my $server = $options{'server'};
my $fqdn = $options{'fqdn'};
my $fqdn_path = $options{'fqdn-path'};
my $use_snapshots = exists $options{'use-snapshots'} ? 1 : 0;
my $use_ttqs = exists $options{'use-ttqs'} ? 1 : 0;
my $out_dir = $options{'out-dir'};
my $no_gc = $options{'no-gc'};
my $procs = $options{'procs'};
my $snapshot_procs = $options{'snapshot-procs'};
my $adaptive = $options{'adaptive'};
my $snapshots_only = $options{'snapshots-only'};
my $partition_data_path = $options{'partition-data-path'};

if ($fqdn_path) {
    my @lines = read_file($fqdn_path);
    chomp for @lines;
    $fqdn = \@lines;
} else {
    $fqdn = [$fqdn];
}

my $client =
    APNIC::RPKI::Erik::Client->new(
        $cache_dir,
        use_snapshots  => $use_snapshots,
        use_ttqs       => $use_ttqs,
        out_dir        => $out_dir,
        no_gc          => $no_gc,
        procs          => $procs,
        snapshot_procs => $snapshot_procs,
        adaptive       => $adaptive,
        snapshots_only => $snapshots_only,
        partition_data_path => $partition_data_path,
    );
my $res = $client->synchronise($server, $fqdn);
exit($res->{'success'} ? 0 : -1);

1;
